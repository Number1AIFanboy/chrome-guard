{
  "manifest_version": 3,
  "name": "Level3ID Chrome Guard",
  "version": "1.0.0",
  "description": "A secure identity verification add-on.",
  "permissions": [
    "storage", 
    "alarms", 
    "tabs"
  ],
  "host_permissions": [
    "https://*.support-775.workers.dev/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "ui/popup.html"
  },
  "options_page": "ui/options.html"
}
